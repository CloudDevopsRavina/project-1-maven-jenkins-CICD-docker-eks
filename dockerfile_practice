# ----------------------
# Stage 1: Build WAR with Maven
# ----------------------
FROM maven:3.8.4-eclipse-temurin-17 AS build

# Set working directory
WORKDIR /app

# Copy project files
COPY . .

# Build the Maven project and generate WAR
RUN mvn clean package

# Debug: verify WAR exists
RUN ls -al /app/webapp/target

# ----------------------
# Stage 2: Tomcat runtime
# ----------------------
FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# Install OpenJDK and utilities
RUN apt-get update && \
    apt-get install -y openjdk-11-jdk wget curl && \
    rm -rf /var/lib/apt/lists/*

# Set Java environment
ENV JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
ENV PATH=$JAVA_HOME/bin:$PATH

# Install Tomcat
ENV TOMCAT_VERSION 9.0.95
ENV CATALINA_HOME=/opt/tomcat
ENV PATH=$CATALINA_HOME/bin:$PATH

RUN wget https://dlcdn.apache.org/tomcat/tomcat-9/v${TOMCAT_VERSION}/bin/apache-tomcat-${TOMCAT_VERSION}.tar.gz -O /tmp/tomcat.tar.gz && \
    mkdir -p $CATALINA_HOME && \
    tar xzvf /tmp/tomcat.tar.gz --strip-components=1 -C $CATALINA_HOME && \
    rm /tmp/tomcat.tar.gz && \
    rm -rf $CATALINA_HOME/webapps/*   # Remove default apps

# Expose Tomcat port
EXPOSE 8080

# Copy WAR from build stage
COPY --from=build /app/webapp/target/webapp.war $CATALINA_HOME/webapps/webapp.war

# Start Tomcat
CMD ["catalina.sh", "run"]
