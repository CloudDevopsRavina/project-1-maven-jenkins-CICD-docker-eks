# ----------------------
# Stage 1: Build WAR using Maven
# ----------------------
FROM maven:3.8.4-eclipse-temurin-17 AS build

WORKDIR /app

COPY . .

RUN mvn clean package

# Debug
RUN ls -al /app/webapp/target


# ----------------------
# Stage 2: Run Tomcat on Ubuntu
# ----------------------
FROM ubuntu:20.04

ENV DEBIAN_FRONTEND=noninteractive

# Install Java + tools
RUN apt-get update && \
    apt-get install -y openjdk-11-jdk wget curl && \
    rm -rf /var/lib/apt/lists/*

# Java setup
ENV JAVA_HOME=/usr/lib/jvm/java-11-openjdk-amd64
ENV PATH=$JAVA_HOME/bin:$PATH

# Tomcat setup
ENV TOMCAT_VERSION=9.0.82
ENV CATALINA_HOME=/opt/tomcat
ENV PATH=$CATALINA_HOME/bin:$PATH

# ✅ Use ARCHIVE URL (NO 404 EVER)
RUN wget https://archive.apache.org/dist/tomcat/tomcat-9/v${TOMCAT_VERSION}/bin/apache-tomcat-${TOMCAT_VERSION}.tar.gz -O /tmp/tomcat.tar.gz && \
    mkdir -p $CATALINA_HOME && \
    tar xzvf /tmp/tomcat.tar.gz --strip-components=1 -C $CATALINA_HOME && \
    rm /tmp/tomcat.tar.gz && \
    rm -rf $CATALINA_HOME/webapps/*

# Expose port
EXPOSE 8080

# Copy WAR
COPY --from=build /app/webapp/target/webapp.war $CATALINA_HOME/webapps/webapp.war

# Start Tomcat
CMD ["catalina.sh", "run"]
